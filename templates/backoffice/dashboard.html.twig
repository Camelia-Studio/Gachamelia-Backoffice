{% extends 'base.html.twig' %}

{% block title %}Serveurs Discord - Gachamélia Backoffice{% endblock %}

{% block navbar_actions %}
    <form method="post" action="{{ path('app_logout') }}">
        <button
            type="submit"
            class="inline-flex min-h-10 cursor-pointer items-center justify-center rounded-full bg-camelia-ink px-4 text-sm font-black text-white shadow-sm transition hover:bg-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60"
        >
            Déconnexion
        </button>
    </form>
{% endblock %}

{% block body %}
    <section class="grid gap-8" data-testid="backoffice-dashboard">
        <div class="grid gap-3 border-b border-camelia-ink/10 pb-6">
            <p class="text-xs font-black tracking-[0.18em] text-camelia-rose uppercase">Serveurs Discord</p>
            <h1 class="font-display text-4xl leading-tight md:text-5xl">Choisir un serveur</h1>
            {% if profile %}
                <p class="max-w-2xl text-sm font-semibold text-camelia-muted">
                    {{ profile.global_name ?? profile.username }}
                </p>
            {% endif %}
        </div>

        {% if guilds is empty %}
            <div class="border border-camelia-ink/10 bg-white p-6 shadow-sm">
                <p class="text-lg font-black">Aucun serveur disponible</p>
                <p class="mt-2 max-w-2xl text-sm leading-6 text-camelia-muted">
                    Le bot Gachamélia doit être présent sur au moins un serveur Discord commun.
                </p>
            </div>
        {% else %}
            <div class="grid gap-3">
                {% for guild in guilds %}
                    <article
                        class="grid gap-4 border border-camelia-ink/10 bg-white p-5 shadow-sm md:grid-cols-[minmax(0,1fr)_auto] md:items-center"
                        data-testid="guild-{{ guild.id }}"
                    >
                        <div class="flex min-w-0 items-center gap-4">
                            {% if guild.icon_url %}
                                <img
                                    src="{{ guild.icon_url }}"
                                    alt="Logo {{ guild.name }}"
                                    width="48"
                                    height="48"
                                    class="size-12 shrink-0 rounded-full border border-camelia-ink/10 bg-camelia-blush object-cover"
                                    loading="lazy"
                                >
                            {% else %}
                                <span
                                    class="flex size-12 shrink-0 items-center justify-center rounded-full border border-camelia-ink/10 bg-camelia-blush font-display text-2xl font-black text-camelia-rose"
                                    data-testid="guild-icon-fallback"
                                    aria-hidden="true"
                                >
                                    {{ guild.name|slice(0, 1)|upper }}
                                </span>
                            {% endif %}
                            <div class="min-w-0">
                                <h2 class="text-lg font-black leading-tight">{{ guild.name }}</h2>
                                <p class="mt-1 text-sm font-semibold text-camelia-muted">
                                    {{ guild.canManageConfiguration ? 'Administration' : 'Membre' }}
                                </p>
                            </div>
                        </div>
                        <div class="flex flex-wrap gap-2">
                            {% if guild.canManageConfiguration %}
                                <a
                                    href="{{ path('app_server_configuration_section', { guildId: guild.id, section: 'ranks' }) }}"
                                    class="inline-flex min-h-10 items-center justify-center rounded-full bg-camelia-leaf px-4 text-sm font-black text-white transition hover:bg-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-leaf/50"
                                >
                                    Configuration
                                </a>
                            {% endif %}
                            <a
                                href="{{ path('app_character_sheet', { guildId: guild.id }) }}"
                                class="inline-flex min-h-10 items-center justify-center rounded-full border border-camelia-ink/10 bg-camelia-blush px-4 text-sm font-black text-camelia-ink transition hover:border-camelia-rose/40 hover:text-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50"
                            >
                                Fiche personnage
                            </a>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </section>
{% endblock %}
