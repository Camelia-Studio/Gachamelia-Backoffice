                                                <details class="group border-t border-camelia-ink/10 pt-3">
                                                    <summary class="cursor-pointer text-sm font-black text-camelia-rose transition hover:text-camelia-ink">Modifier</summary>
                                                    <div class="mt-4 grid gap-4">
                                                        <form method="post" action="{{ path('app_server_catalog_role_update', { guildId: guild.id, roleId: role.id }) }}" class="grid gap-4" data-controller="emoji-picker" data-emoji-picker-default-value="{{ role.emoji_markup }}">
                                                            <div class="grid gap-3 md:grid-cols-[minmax(0,1fr)_6rem]">
                                                                <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                                                    Nom
                                                                    <input name="name" value="{{ role.name }}" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                                                </label>
                                                                <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                                                    %
                                                                    <input name="percentage" type="number" min="0" max="100" value="{{ role.percentage }}" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
