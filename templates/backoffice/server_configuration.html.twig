{% extends 'base.html.twig' %}

{% macro emoji_picker(default_source, default_value, picker, tone) %}
    {% set groups = [
        { id: 'standard', label: 'Standard', options: picker.standard },
        { id: 'bot', label: 'Bot', options: picker.bot },
        { id: 'server', label: 'Serveur', options: picker.server },
    ] %}

    <input type="hidden" name="emoji_source" value="{{ default_source }}" data-emoji-picker-target="source">
    <input type="hidden" name="emoji_value" value="{{ default_value }}" data-emoji-picker-target="value">

    <div class="grid gap-4" data-testid="emoji-picker">
        <label class="grid gap-1 text-sm font-bold text-camelia-muted">
            Rechercher un emoji
            <input type="search" class="min-h-11 w-full border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50" placeholder="Nom de l’emoji" data-emoji-picker-target="search" data-action="input->emoji-picker#filter">
        </label>

        <div class="grid max-h-72 gap-4 overflow-y-auto border border-camelia-ink/10 bg-white p-3">
            {% for group in groups %}
                <section class="grid gap-2" data-emoji-picker-target="group">
                    <p class="text-[0.68rem] font-black tracking-[0.16em] text-camelia-muted uppercase">{{ group.label }}</p>
                    <div class="grid grid-cols-[repeat(auto-fill,minmax(3.25rem,1fr))] gap-2">
                        {% for option in group.options %}
                            {% set test_id = option.discord_id ? 'emoji-picker-option-' ~ option.source ~ '-' ~ option.discord_id : 'emoji-picker-option-standard-' ~ loop.index %}
                            <button
                                type="button"
                                class="grid min-h-14 place-items-center border border-camelia-ink/10 bg-camelia-ivory p-2 text-center transition hover:border-camelia-rose/40 hover:bg-camelia-blush/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60 data-[selected=true]:border-camelia-rose data-[selected=true]:bg-camelia-blush"
                                data-emoji-picker-target="option"
                                data-action="click->emoji-picker#choose"
                                data-emoji-source="{{ option.source }}"
                                data-emoji-value="{{ option.value }}"
                                data-emoji-name="{{ option.name }}"
                                data-emoji-cdn-url="{{ option.cdn_url }}"
                                data-testid="{{ test_id }}"
                                title="{{ option.name }}"
                            >
                                {% if option.cdn_url %}
                                    <img src="{{ option.cdn_url }}" alt="" class="size-8 object-contain" loading="lazy">
                                {% else %}
                                    <span class="text-2xl leading-none">{{ option.markup }}</span>
                                {% endif %}
                                <span class="mt-1 max-w-full truncate text-[0.62rem] font-black text-camelia-muted">{{ option.name }}</span>
                            </button>
                        {% else %}
                            <span class="col-span-full border border-dashed border-camelia-ink/15 bg-camelia-blush/30 px-3 py-2 text-xs font-bold text-camelia-muted">Aucun emoji en cache.</span>
                        {% endfor %}
                    </div>
                </section>
            {% endfor %}
        </div>

        <div class="grid gap-4 border border-camelia-ink/10 bg-camelia-blush/50 p-4 sm:grid-cols-[5rem_minmax(0,1fr)] sm:items-center" data-testid="emoji-preview">
            <span class="relative flex size-20 shrink-0 items-center justify-center overflow-hidden {{ tone }}">
                <img
                    alt=""
                    class="hidden size-full object-contain"
                    data-emoji-picker-target="image"
                    data-action="load->emoji-picker#imageLoaded error->emoji-picker#imageError"
                >
                <span class="flex size-full items-center justify-center font-display text-2xl font-black text-camelia-rose" data-emoji-picker-target="glyph">{{ default_value }}</span>
            </span>
            <div>
                <strong class="text-sm">Prévisualisation Discord</strong>
                <p class="mt-1 text-xs font-bold leading-relaxed text-camelia-muted" data-emoji-picker-target="status">Emoji sélectionné pour les fiches.</p>
            </div>
        </div>
    </div>
{% endmacro %}

{% import _self as ui %}

{% block title %}Configuration - {{ guild.name }} - Gachamélia Backoffice{% endblock %}

{% block navbar_actions %}
    <a
        href="{{ path('app_dashboard') }}"
        class="inline-flex min-h-10 items-center justify-center rounded-full border border-camelia-ink/10 bg-white px-4 text-sm font-black text-camelia-ink shadow-sm transition hover:border-camelia-rose/30 hover:text-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60"
    >
        Serveurs
    </a>
{% endblock %}

{% block body %}
    {% set is_overview = active_section == 'overview' %}
    {% set page_icon = is_overview ? 'CF' : active_configuration_section.icon %}
    {% set page_title = is_overview ? 'Configuration du serveur' : active_configuration_section.label %}
    {% set page_description = is_overview ? 'Choisis une partie du catalogue à compléter pour ce serveur.' : active_configuration_section.description %}

    <section class="grid gap-10" data-testid="server-configuration">
        <div class="grid gap-8 lg:grid-cols-[16.5rem_minmax(0,1fr)] xl:gap-12">
            <aside class="lg:sticky lg:top-28 lg:self-start">
                <div class="grid gap-7">
                    <div class="flex items-center gap-4 border border-camelia-ink/10 bg-camelia-ivory p-4 shadow-sm">
                        {% if guild.icon_url %}
                            <img
                                src="{{ guild.icon_url }}"
                                alt="Logo {{ guild.name }}"
                                width="48"
                                height="48"
                                class="size-12 shrink-0 rounded-full border border-camelia-ink/10 bg-camelia-blush object-cover"
                                loading="lazy"
                            >
                        {% else %}
                            <span
                                class="flex size-12 shrink-0 items-center justify-center rounded-full border border-camelia-ink/10 bg-camelia-blush font-display text-2xl font-black text-camelia-rose"
                                data-testid="guild-icon-fallback"
                                aria-hidden="true"
                            >
                                {{ guild.name|slice(0, 1)|upper }}
                            </span>
                        {% endif %}
                        <div class="min-w-0">
                            <p class="truncate text-sm font-black leading-tight">{{ guild.name }}</p>
                            <p class="mt-1 text-xs font-bold leading-tight text-camelia-muted">Catalogue actif</p>
                        </div>
                    </div>

                    <nav class="grid gap-7" aria-label="Sections de configuration" data-testid="configuration-sidebar">
                        <div class="grid gap-2">
                            <p class="px-3 text-[0.68rem] font-black tracking-[0.16em] text-camelia-muted uppercase">Serveur</p>
                            <a
                                href="{{ path('app_character_sheet', { guildId: guild.id }) }}"
                                class="grid min-h-12 grid-cols-[1.8rem_minmax(0,1fr)] items-center gap-3 px-3 text-sm font-black text-camelia-muted transition hover:text-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60"
                            >
                                <span class="flex size-7 items-center justify-center border border-camelia-ink/10 bg-white text-[0.68rem] font-black text-camelia-rose">FP</span>
                                Fiche personnage
                            </a>
                            <a
                                href="{{ path('app_server_configuration', { guildId: guild.id }) }}"
                                class="relative grid min-h-12 grid-cols-[1.8rem_minmax(0,1fr)] items-center gap-3 px-3 text-sm font-black transition focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60 {{ is_overview ? 'bg-camelia-blush text-camelia-ink before:absolute before:left-0 before:h-7 before:w-1 before:rounded-full before:bg-camelia-rose' : 'text-camelia-muted hover:text-camelia-rose' }}"
                                data-testid="configuration-nav-overview"
                                {% if is_overview %}aria-current="page"{% endif %}
                            >
                                <span class="flex size-7 items-center justify-center border border-camelia-ink/10 bg-white text-[0.68rem] font-black text-camelia-rose">CF</span>
                                Configuration
                            </a>
                        </div>

                        <div class="grid gap-2">
                            <p class="px-3 text-[0.68rem] font-black tracking-[0.16em] text-camelia-muted uppercase">Catalogue</p>
                            {% for section in configuration_sections %}
                                {% set is_active = section.id == active_section %}
                                <a
                                    href="{{ path('app_server_configuration_section', { guildId: guild.id, section: section.id }) }}"
                                    class="relative grid min-h-12 grid-cols-[1.8rem_minmax(0,1fr)_auto] items-center gap-3 px-3 text-sm font-black transition focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60 {{ is_active ? 'bg-camelia-blush text-camelia-ink before:absolute before:left-0 before:h-7 before:w-1 before:rounded-full before:bg-camelia-rose' : 'text-camelia-muted hover:text-camelia-rose' }}"
                                    data-testid="configuration-nav-{{ section.id }}"
                                    {% if is_active %}aria-current="page"{% endif %}
                                >
                                    <span class="flex size-7 items-center justify-center border border-camelia-ink/10 bg-white text-[0.68rem] font-black text-camelia-rose">{{ section.icon }}</span>
                                    <span>{{ section.label }}</span>
                                    <span class="text-xs font-black text-camelia-rose">{{ section.count }}</span>
                                </a>
                            {% endfor %}
                        </div>
                    </nav>
                </div>
            </aside>

            <div class="grid min-w-0 gap-8">
                <header class="flex items-start gap-5 border-b border-camelia-ink/10 pb-8">
                    <span class="flex size-16 shrink-0 items-center justify-center border border-camelia-ink/10 bg-camelia-blush font-display text-2xl font-black text-camelia-rose">
                        {{ page_icon }}
                    </span>
                    <div class="min-w-0">
                        <p class="text-xs font-black tracking-[0.18em] text-camelia-rose uppercase">{{ guild.name }} · Catalogue</p>
                        <h1 class="mt-2 font-display text-4xl leading-tight md:text-5xl">{{ page_title }}</h1>
                        <p class="mt-4 max-w-3xl text-base font-bold leading-relaxed text-camelia-muted">{{ page_description }}</p>
                    </div>
                </header>

                {% if is_overview %}
                    <section class="grid gap-7" data-testid="configuration-overview">
                        <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
                            {% for section in configuration_sections %}
                                {% set tone = loop.index == 2 ? 'bg-camelia-gold/20 text-[#7a5415]' : (loop.index == 3 ? 'bg-camelia-leaf/15 text-camelia-leaf' : 'bg-camelia-blush text-camelia-rose') %}
                                <article
                                    class="grid min-h-72 gap-6 border border-camelia-ink/10 bg-camelia-ivory p-7 shadow-sm"
                                    data-testid="configuration-overview-card-{{ section.id }}"
                                >
                                    <div class="flex items-start justify-between gap-4">
                                        <span class="flex size-14 items-center justify-center {{ tone }} font-display text-xl font-black">{{ section.icon }}</span>
                                        <span class="inline-flex min-h-8 items-center rounded-full bg-camelia-gold/20 px-4 text-xs font-black text-[#7a5415]">{{ section.count }} entrées</span>
                                    </div>
                                    <div class="grid gap-3">
                                        <h2 class="text-xl font-black">{{ section.label }}</h2>
                                        <p class="max-w-sm text-base font-bold leading-relaxed text-camelia-muted">{{ section.description }}</p>
                                    </div>
                                    <a
                                        href="{{ path('app_server_configuration_section', { guildId: guild.id, section: section.id }) }}"
                                        class="mt-auto inline-flex min-h-11 items-center justify-center justify-self-start rounded-full bg-camelia-ink px-5 text-sm font-black text-white transition hover:bg-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60"
                                    >
                                        Configurer
                                    </a>
                                </article>
                            {% endfor %}
                        </div>
                    </section>
                {% else %}
                    <div data-testid="configuration-panel">
                        {% if active_section == 'ranks' %}
                            <div class="grid gap-7 xl:grid-cols-[minmax(20rem,26rem)_minmax(0,1fr)]">
                                <section class="grid gap-6 border border-camelia-ink/10 bg-camelia-ivory shadow-sm" data-testid="catalog-create-panel">
                                    <div class="border-b border-camelia-ink/10 p-6">
                                        <h2 class="text-lg font-black">Ajouter un rang</h2>
                                        <p class="mt-1 text-sm font-bold text-camelia-muted">Renseigne les infos minimales pour alimenter le bot.</p>
                                    </div>
                                    <form method="post" action="{{ path('app_server_catalog_rank_create', { guildId: guild.id }) }}" class="grid gap-5 p-6">
                                        <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                            ID Discord
                                            <input name="discord_id" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                        </label>
                                        <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                            Nom
                                            <input name="name" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                        </label>
                                        <div class="grid gap-3 md:grid-cols-[minmax(0,1fr)_6rem]">
                                            <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                                Titre du message de départ
                                                <input name="bye_title" class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                            </label>
                                            <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                                %
                                                <input name="percentage" type="number" min="0" max="100" value="0" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                            </label>
                                        </div>
                                        <label class="flex items-center justify-between gap-3 border border-camelia-ink/10 bg-camelia-blush/60 px-3 py-3 text-sm font-black text-camelia-ink">
                                            Rang staff prioritaire
                                            <input name="is_staff" type="checkbox" value="1" class="size-4 accent-camelia-rose">
                                        </label>
                                        <button type="submit" class="inline-flex min-h-11 items-center justify-center rounded-full bg-camelia-ink px-5 text-sm font-black text-white transition hover:bg-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60">
                                            Ajouter le rang
                                        </button>
                                    </form>
                                </section>

                                <section class="grid gap-6 border border-camelia-ink/10 bg-camelia-ivory shadow-sm" data-testid="catalog-list-panel">
                                    <div class="flex items-start justify-between gap-4 border-b border-camelia-ink/10 p-6">
                                        <div>
                                            <h2 class="text-lg font-black">Rangs existants</h2>
                                            <p class="mt-1 text-sm font-bold text-camelia-muted">Les données affichées restent strictement celles de ce serveur.</p>
                                        </div>
                                        <span class="inline-flex min-h-7 items-center rounded-full bg-camelia-gold/20 px-3 text-xs font-black text-[#7a5415]">{{ catalog.ranks|length }} entrées</span>
                                    </div>
                                    <div class="grid gap-4 p-6">
                                        {% for rank in catalog.ranks %}
                                            <article class="grid gap-5 border border-camelia-ink/10 bg-white p-5 text-sm" data-testid="rank-card">
                                                <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_auto] md:items-center">
                                                    <div class="flex min-w-0 items-center gap-3">
                                                        <span class="flex size-12 shrink-0 items-center justify-center bg-camelia-blush font-display text-lg font-black text-camelia-rose">{{ rank.name|slice(0, 1)|upper }}</span>
                                                        <div class="min-w-0">
                                                            <strong class="block truncate">{{ rank.name }}</strong>
                                                            <p class="mt-1 truncate font-semibold text-camelia-muted">{{ rank.discord_id }}{% if rank.bye_title %} · {{ rank.bye_title }}{% endif %}</p>
                                                        </div>
                                                    </div>
                                                    <div class="flex flex-wrap gap-2 md:justify-end">
                                                        {% if rank.is_staff %}
                                                            <span class="inline-flex min-h-7 items-center rounded-full bg-camelia-leaf/15 px-3 text-xs font-black text-camelia-leaf">Staff</span>
                                                        {% endif %}
                                                        <span class="inline-flex min-h-7 items-center rounded-full bg-camelia-blush px-3 text-xs font-black text-camelia-rose">{{ rank.percentage }}%</span>
                                                    </div>
                                                </div>
                                                <details class="group border-t border-camelia-ink/10 pt-4">
                                                    <summary class="cursor-pointer text-sm font-black text-camelia-rose transition hover:text-camelia-ink">Configurer le rang</summary>
                                                    <div class="mt-5 grid gap-6">
                                                        <form method="post" action="{{ path('app_server_catalog_rank_update', { guildId: guild.id, rankId: rank.id }) }}" class="grid gap-4 border border-camelia-ink/10 bg-camelia-ivory p-4">
                                                            <div class="grid gap-3 md:grid-cols-2">
                                                                <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                                                    ID Discord
                                                                    <input name="discord_id" value="{{ rank.discord_id }}" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                                                </label>
                                                                <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                                                    Nom
                                                                    <input name="name" value="{{ rank.name }}" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                                                </label>
                                                            </div>
                                                            <div class="grid gap-3 md:grid-cols-[minmax(0,1fr)_6rem]">
                                                                <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                                                    Titre du message de départ
                                                                    <input name="bye_title" value="{{ rank.bye_title }}" class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                                                </label>
                                                                <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                                                    %
                                                                    <input name="percentage" type="number" min="0" max="100" value="{{ rank.percentage }}" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                                                </label>
                                                            </div>
                                                            <div class="flex flex-wrap items-center justify-between gap-3">
                                                                <label class="inline-flex min-h-10 items-center gap-3 border border-camelia-ink/10 bg-white px-3 text-sm font-black text-camelia-ink">
                                                                    <input name="is_staff" type="checkbox" value="1" class="size-4 accent-camelia-rose" {% if rank.is_staff %}checked{% endif %}>
                                                                    Rang staff
                                                                </label>
                                                                <button type="submit" class="inline-flex min-h-10 items-center justify-center rounded-full bg-camelia-ink px-5 text-sm font-black text-white transition hover:bg-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60">
                                                                    Enregistrer
                                                                </button>
                                                            </div>
                                                        </form>

                                                        <form method="post" action="{{ path('app_server_catalog_rank_delete', { guildId: guild.id, rankId: rank.id }) }}" class="justify-self-start">
                                                            <button type="submit" class="inline-flex min-h-10 items-center justify-center rounded-full border border-camelia-rose/30 bg-white px-5 text-sm font-black text-camelia-rose transition hover:bg-camelia-blush focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60">
                                                                Supprimer le rang
                                                            </button>
                                                        </form>
                                                    </div>
                                                </details>
                                            </article>
                                        {% else %}
                                            <p class="border border-dashed border-camelia-ink/20 bg-camelia-blush/50 p-5 text-sm font-bold text-camelia-muted">Aucun rang pour l’instant. Ajoute le premier rang de ce serveur.</p>
                                        {% endfor %}
                                    </div>
                                </section>
                            </div>
                        {% elseif active_section == 'rank-stats' %}
                            <div class="grid gap-8 xl:grid-cols-[minmax(22rem,28rem)_minmax(0,1fr)] xl:items-start">
                                <section class="grid gap-6 border border-camelia-ink/10 bg-camelia-ivory shadow-sm" data-testid="catalog-create-panel">
                                    <div class="border-b border-camelia-ink/10 p-6">
                                        <h2 class="text-lg font-black">Lier une stat à un rang</h2>
                                        <p class="mt-2 text-sm font-bold leading-relaxed text-camelia-muted">Cette probabilité nourrit le catalogue du rang sans encombrer sa fiche principale.</p>
                                    </div>
                                    <form method="post" action="{{ path('app_server_catalog_rank_stat_upsert_dedicated', { guildId: guild.id }) }}" class="grid gap-5 p-6">
                                        <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                            Rang
                                            <select name="rank_id" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                                {% for rank in catalog.ranks %}
                                                    <option value="{{ rank.id }}">{{ rank.name }}</option>
                                                {% else %}
                                                    <option value="">Ajoute un rang d’abord</option>
                                                {% endfor %}
                                            </select>
                                        </label>
                                        <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_7rem]">
                                            <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                                Stat
                                                <select name="stat_id" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                                    {% for stat in catalog.stats %}
                                                        <option value="{{ stat.id }}">{{ stat.name }}</option>
                                                    {% else %}
                                                        <option value="">Ajoute une stat d’abord</option>
                                                    {% endfor %}
                                                </select>
                                            </label>
                                            <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                                %
                                                <input name="percentage" type="number" min="0" max="100" value="0" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                            </label>
                                        </div>
                                        <button type="submit" class="inline-flex min-h-11 items-center justify-center rounded-full bg-camelia-ink px-5 text-sm font-black text-white transition hover:bg-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60">
                                            Enregistrer la probabilité
                                        </button>
                                    </form>
                                </section>

                                <section class="grid gap-6 border border-camelia-ink/10 bg-camelia-ivory shadow-sm" data-testid="catalog-list-panel">
                                    <div class="flex items-start justify-between gap-4 border-b border-camelia-ink/10 p-6">
                                        <div>
                                            <h2 class="text-lg font-black">Stats liées aux rangs</h2>
                                            <p class="mt-2 text-sm font-bold leading-relaxed text-camelia-muted">Chaque ligne associe une caractéristique à un rang de ce serveur.</p>
                                        </div>
                                        <span class="inline-flex min-h-7 items-center rounded-full bg-camelia-gold/20 px-3 text-xs font-black text-[#7a5415]">{{ catalog.rank_stats|length }} entrées</span>
                                    </div>
                                    <div class="grid gap-4 p-6">
                                        {% for rank_stat in catalog.rank_stats %}
                                            <article class="grid gap-4 border border-camelia-ink/10 bg-white p-5" data-testid="rank-stat-card">
                                                <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_auto] md:items-center">
