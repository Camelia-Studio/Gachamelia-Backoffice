                                        {% endfor %}
                                    </div>
                                </section>
                            </div>
                        {% elseif active_section in ['welcome-messages', 'bye-messages'] %}
                            {% set is_welcome_messages = active_section == 'welcome-messages' %}
                            {% set messages = is_welcome_messages ? catalog.welcome_messages : catalog.bye_messages %}
                            {% set create_route = is_welcome_messages ? 'app_server_catalog_welcome_message_create' : 'app_server_catalog_bye_message_create' %}
                            {% set update_route = is_welcome_messages ? 'app_server_catalog_welcome_message_update' : 'app_server_catalog_bye_message_update' %}
                            {% set delete_route = is_welcome_messages ? 'app_server_catalog_welcome_message_delete' : 'app_server_catalog_bye_message_delete' %}
                            {% set create_title = is_welcome_messages ? 'Ajouter un message d’arrivée' : 'Ajouter un message de départ' %}
                            {% set list_title = is_welcome_messages ? 'Messages d’arrivée' : 'Messages de départ' %}
                            {% set submit_label = is_welcome_messages ? 'Ajouter le message d’arrivée' : 'Ajouter le message de départ' %}
