                                        <p class="mt-2 text-sm font-bold leading-relaxed text-camelia-muted">Le message reste rattaché au rang sélectionné et uniquement à ce serveur.</p>
                                    </div>
                                    <form method="post" action="{{ path(create_route, { guildId: guild.id }) }}" class="grid gap-5 p-6">
                                        <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                            Rang
                                            <select name="rank_id" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                                {% for rank in catalog.ranks %}
                                                    <option value="{{ rank.id }}">{{ rank.name }}</option>
                                                {% else %}
                                                    <option value="">Ajoute un rang d’abord</option>
                                                {% endfor %}
                                            </select>
                                        </label>
                                        <label class="grid gap-2 text-sm font-bold text-camelia-muted">
                                            Message
                                            <textarea name="message" required maxlength="255" rows="5" class="min-h-32 resize-y border border-camelia-ink/10 bg-white px-3 py-3 font-semibold leading-relaxed text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50"></textarea>
                                        </label>
                                        <button type="submit" class="inline-flex min-h-11 items-center justify-center rounded-full bg-camelia-ink px-5 text-sm font-black text-white transition hover:bg-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60">
                                            {{ submit_label }}
                                        </button>
                                    </form>
                                </section>

                                <section class="grid gap-6 border border-camelia-ink/10 bg-camelia-ivory shadow-sm" data-testid="catalog-list-panel">
                                    <div class="flex items-start justify-between gap-4 border-b border-camelia-ink/10 p-6">
                                        <div>
                                            <h2 class="text-lg font-black">{{ list_title }}</h2>
                                            <p class="mt-2 text-sm font-bold leading-relaxed text-camelia-muted">Une page dédiée pour relire, corriger et supprimer les variantes.</p>
                                        </div>
                                        <span class="inline-flex min-h-7 items-center rounded-full bg-camelia-blush px-3 text-xs font-black text-camelia-rose">{{ messages|length }} entrées</span>
                                    </div>
                                    <div class="grid gap-4 p-6">
                                        {% for message in messages %}
                                            <article class="grid gap-4 border border-camelia-ink/10 bg-white p-5" data-testid="message-card">
                                                <div class="flex flex-wrap items-center justify-between gap-3">
                                                    <div class="min-w-0">
                                                        <strong class="block truncate">{{ message.rank_name }}</strong>
                                                        <p class="mt-1 text-xs font-black tracking-[0.14em] text-camelia-rose uppercase">Rang lié</p>
                                                    </div>
                                                    <span class="inline-flex min-h-7 items-center rounded-full bg-camelia-gold/20 px-3 text-xs font-black text-[#7a5415]">#{{ message.id }}</span>
                                                </div>
                                                <form method="post" action="{{ path(update_route, { guildId: guild.id, messageId: message.id }) }}" class="grid gap-4">
                                                    <label class="grid gap-2 text-sm font-bold text-camelia-muted">
                                                        Message
                                                        <textarea name="message" required maxlength="255" rows="4" class="min-h-28 resize-y border border-camelia-ink/10 bg-camelia-ivory px-3 py-3 font-semibold leading-relaxed text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">{{ message.message }}</textarea>
                                                    </label>
                                                    <div class="flex flex-wrap gap-3">
                                                        <button type="submit" class="inline-flex min-h-10 items-center justify-center rounded-full bg-camelia-ink px-5 text-sm font-black text-white transition hover:bg-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60">
                                                            Enregistrer
                                                        </button>
                                                    </div>
                                                </form>
                                                <form method="post" action="{{ path(delete_route, { guildId: guild.id, messageId: message.id }) }}">
                                                    <button type="submit" class="inline-flex min-h-10 items-center justify-center rounded-full border border-camelia-rose/30 bg-white px-5 text-sm font-black text-camelia-rose transition hover:bg-camelia-blush focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60">
                                                        Supprimer
                                                    </button>
                                                </form>
                                            </article>
                                        {% else %}
                                            <p class="border border-dashed border-camelia-ink/20 bg-camelia-blush/50 p-5 text-sm font-bold text-camelia-muted">Aucun message enregistré pour l’instant.</p>
                                        {% endfor %}
                                    </div>
                                </section>
                            </div>
                        {% elseif active_section == 'roles' %}
