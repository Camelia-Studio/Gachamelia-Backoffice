                                                    <div class="mt-4 grid gap-4">
                                                        <form method="post" action="{{ path('app_server_catalog_rank_stat_upsert_dedicated', { guildId: guild.id }) }}" class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_7rem_auto] sm:items-end">
                                                            <input type="hidden" name="rank_id" value="{{ rank_stat.rank_id }}">
                                                            <input type="hidden" name="stat_id" value="{{ rank_stat.stat_id }}">
