                                                                <input value="{{ rank_stat.rank_name }} · {{ rank_stat.stat_name }}" disabled class="min-h-11 border border-camelia-ink/10 bg-camelia-ivory px-3 font-semibold text-camelia-muted">
                                                            </label>
                                                            <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                                                %
                                                                <input name="percentage" type="number" min="0" max="100" value="{{ rank_stat.percentage }}" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                                            </label>
                                                            <button type="submit" class="inline-flex min-h-11 items-center justify-center rounded-full bg-camelia-ink px-5 text-sm font-black text-white transition hover:bg-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60">
                                                                Enregistrer
                                                            </button>
                                                        </form>
                                                        <form method="post" action="{{ path('app_server_catalog_rank_stat_delete_dedicated', { guildId: guild.id, rankId: rank_stat.rank_id, statId: rank_stat.stat_id }) }}">
