                                                    <summary class="cursor-pointer text-sm font-black text-camelia-rose transition hover:text-camelia-ink">Modifier</summary>
                                                    <div class="mt-4 grid gap-4">
                                                        <form method="post" action="{{ path('app_server_catalog_element_update', { guildId: guild.id, elementId: element.id }) }}" class="grid gap-4" data-controller="emoji-picker" data-emoji-picker-default-value="{{ element.emoji_markup }}">
                                                            <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                                                                Nom
                                                                <input name="name" value="{{ element.name }}" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                                                            </label>
                                                            {{ ui.emoji_picker(element.emoji_source, element.emoji_markup, emoji_picker, 'bg-camelia-blush') }}
                                                            <button type="submit" class="inline-flex min-h-10 items-center justify-center rounded-full bg-camelia-ink px-5 text-sm font-black text-white transition hover:bg-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60">
                                                                Enregistrer
                                                            </button>
                                                        </form>
                                                        <form method="post" action="{{ path('app_server_catalog_element_delete', { guildId: guild.id, elementId: element.id }) }}">
                                                            <button type="submit" class="inline-flex min-h-10 items-center justify-center rounded-full border border-camelia-rose/30 bg-white px-5 text-sm font-black text-camelia-rose transition hover:bg-camelia-blush focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60">
                                                                Supprimer
                                                            </button>
                                                        </form>
                                                    </div>
                                                </details>
                                            </article>
                                        {% else %}
                                            <p class="border border-dashed border-camelia-ink/20 bg-camelia-blush/50 p-5 text-sm font-bold text-camelia-muted sm:col-span-2 2xl:col-span-3">Aucun élément pour l’instant. Ajoute la première affinité du serveur.</p>
                                        {% endfor %}
                                    </div>
                                </section>
                            </div>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}
