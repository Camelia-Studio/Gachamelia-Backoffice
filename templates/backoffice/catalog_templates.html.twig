{% extends 'base.html.twig' %}

{% block title %}Modèles de catalogue - Gachamélia Backoffice{% endblock %}

{% block navbar_actions %}
    <a
        href="{{ path('app_dashboard') }}"
        class="inline-flex min-h-10 items-center justify-center rounded-full border border-camelia-ink/10 bg-white px-4 text-sm font-black text-camelia-ink shadow-sm transition hover:border-camelia-rose/30 hover:text-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60"
    >
        Serveurs
    </a>
{% endblock %}

{% block body %}
    <section class="grid gap-8" data-testid="catalog-templates">
        <header class="grid gap-3 border-b border-camelia-ink/10 pb-6">
            <p class="text-xs font-black tracking-[0.18em] text-camelia-rose uppercase">Administration globale</p>
            <h1 class="font-display text-4xl leading-tight md:text-5xl">Modèles de catalogue</h1>
            <p class="max-w-3xl text-sm font-bold leading-relaxed text-camelia-muted">
                Prépare des catalogues complets que les serveurs pourront importer quand ils veulent démarrer proprement.
            </p>
        </header>

        <div class="grid gap-7 xl:grid-cols-[minmax(20rem,28rem)_minmax(0,1fr)] xl:items-start">
            <section class="grid gap-6 border border-camelia-ink/10 bg-camelia-ivory shadow-sm" data-testid="catalog-template-create-panel">
                <div class="border-b border-camelia-ink/10 p-6">
                    <h2 class="text-lg font-black">Créer un modèle</h2>
                    <p class="mt-2 text-sm font-bold leading-relaxed text-camelia-muted">Le contenu se configure ensuite section par section.</p>
                </div>
                <form method="post" action="{{ path('app_catalog_template_create') }}" class="grid gap-5 p-6">
                    <input type="hidden" name="_token" value="{{ csrf_token('backoffice') }}">
                    <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                        Nom
                        <input name="name" required class="min-h-11 border border-camelia-ink/10 bg-white px-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50">
                    </label>
                    <label class="grid gap-1 text-sm font-bold text-camelia-muted">
                        Description
                        <textarea name="description" rows="4" class="min-h-24 border border-camelia-ink/10 bg-white px-3 py-3 font-semibold text-camelia-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/50"></textarea>
                    </label>
                    <button type="submit" class="inline-flex min-h-11 items-center justify-center rounded-full bg-camelia-ink px-5 text-sm font-black text-white transition hover:bg-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60">
                        Créer le modèle
                    </button>
                </form>
            </section>

            <section class="grid gap-6 border border-camelia-ink/10 bg-camelia-ivory shadow-sm" data-testid="catalog-template-list-panel">
                <div class="flex items-start justify-between gap-4 border-b border-camelia-ink/10 p-6">
                    <div>
                        <h2 class="text-lg font-black">Modèles existants</h2>
                        <p class="mt-2 text-sm font-bold leading-relaxed text-camelia-muted">Seuls les modèles publiés sont proposés à l’import côté serveur.</p>
                    </div>
                    <span class="inline-flex min-h-7 items-center rounded-full bg-camelia-gold/20 px-3 text-xs font-black text-[#7a5415]">{{ templates|length }} modèles</span>
                </div>
                <div class="grid gap-4 p-6">
                    {% for template in templates %}
                        <article class="grid gap-4 border border-camelia-ink/10 bg-white p-5 md:grid-cols-[minmax(0,1fr)_auto] md:items-center" data-testid="catalog-template-card">
                            <div class="min-w-0">
                                <div class="flex flex-wrap items-center gap-2">
                                    <h3 class="text-lg font-black">{{ template.name }}</h3>
                                    <span class="inline-flex min-h-7 items-center rounded-full {{ template.published ? 'bg-camelia-leaf/15 text-camelia-leaf' : 'bg-camelia-blush text-camelia-rose' }} px-3 text-xs font-black">
                                        {{ template.published ? 'Publié' : 'Brouillon' }}
                                    </span>
                                </div>
                                {% if template.description %}
                                    <p class="mt-2 text-sm font-bold leading-relaxed text-camelia-muted">{{ template.description }}</p>
                                {% endif %}
                                <p class="mt-2 text-xs font-black uppercase tracking-[0.12em] text-camelia-muted">{{ template.total_count }} entrées</p>
                            </div>
                            <a
                                href="{{ path('app_catalog_template_configuration', { templateId: template.id }) }}"
                                class="inline-flex min-h-10 items-center justify-center rounded-full bg-camelia-ink px-4 text-sm font-black text-white transition hover:bg-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60"
                            >
                                Configurer
                            </a>
                        </article>
                    {% else %}
                        <p class="border border-dashed border-camelia-ink/15 bg-white p-6 text-sm font-bold leading-relaxed text-camelia-muted">
                            Aucun modèle pour le moment.
                        </p>
                    {% endfor %}
                </div>
            </section>
        </div>
    </section>
{% endblock %}
