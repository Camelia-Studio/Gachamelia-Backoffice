{% extends 'base.html.twig' %}

{% block title %}Erreur {{ status_code|default(500) }} - Gachamélia Backoffice{% endblock %}

{% block meta_description %}Une erreur empêche le backoffice Gachamélia d’afficher l’écran demandé.{% endblock %}

{% block body %}
    {% set errorCode = status_code|default(500) %}

    <section class="grid flex-1 gap-8 py-8 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,27rem)] lg:items-center lg:py-16" data-testid="backoffice-error-page">
        <div class="max-w-3xl">
            <p class="mb-5 inline-flex border-b-2 border-camelia-pink pb-2 text-xs font-black tracking-[0.18em] text-camelia-rose uppercase">
                Erreur <span data-testid="backoffice-error-code">{{ errorCode }}</span>
            </p>
            <h1 class="font-display text-5xl leading-[0.92] tracking-normal text-camelia-ink sm:text-6xl lg:text-7xl" data-testid="backoffice-error-title">
                {{ block('error_title')|trim }}
            </h1>
            <p class="mt-6 max-w-2xl text-lg leading-8 text-camelia-muted">
                {{ block('error_message')|trim }}
            </p>
            <div class="mt-8 flex flex-wrap gap-3">
                <a
                    href="{{ path('app_home') }}"
                    class="inline-flex min-h-12 items-center justify-center rounded-full bg-camelia-ink px-6 text-sm font-black text-white shadow-lg shadow-camelia-ink/10 transition hover:bg-camelia-rose focus:outline-none focus-visible:ring-2 focus-visible:ring-camelia-rose/60"
                    data-testid="backoffice-error-home-action"
                >
                    Retour à l’accueil public
                </a>
            </div>
        </div>

        <aside class="overflow-hidden rounded-[2rem] bg-camelia-ivory shadow-xl shadow-camelia-ink/5 ring-1 ring-camelia-ink/8">
            <div class="bg-camelia-ink p-6 text-white">
                <p class="text-xs font-black tracking-[0.18em] text-camelia-blush uppercase">État du tirage</p>
                <p class="mt-8 font-display text-6xl leading-none">{{ errorCode }}</p>
            </div>
            <div class="grid gap-3 p-4">
                <div class="rounded-[1.25rem] bg-white p-4">
                    <small class="text-xs font-black tracking-wider text-camelia-muted uppercase">Écran</small>
                    <b class="mt-2 block text-lg">{{ block('error_card_title')|trim }}</b>
                </div>
                <div class="rounded-[1.25rem] bg-camelia-blush p-4">
                    <small class="text-xs font-black tracking-wider text-camelia-muted uppercase">Action</small>
                    <b class="mt-2 block text-lg">{{ block('error_card_action')|trim }}</b>
                </div>
            </div>
        </aside>
    </section>
{% endblock %}

{% block error_title %}Le tirage a déraillé{% endblock %}
{% block error_message %}L’écran demandé n’a pas pu être servi. Reviens à l’accueil public pour reprendre une route connue pendant que l’équipe garde le backoffice sous contrôle.{% endblock %}
{% block error_card_title %}Réponse indisponible{% endblock %}
{% block error_card_action %}Revenir sur une page stable{% endblock %}
